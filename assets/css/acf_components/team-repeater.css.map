.team-list .team-list {
  padding: 10px 0 !important;
}
.team-list .team-list .acf-repeater .acf-row-handle.order {
  background: #05a921 !important;
}
.team-list .team-list table > tbody {
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.team-list .team-list [data-name=link] {
  padding: 0 !important;
}
.team-list .team-list .link-wrap {
  display: inline-flex !important;
  flex-wrap: wrap;
}
.team-list .team-list .link-url,
.team-list .team-list .link-title {
  padding: 0 5px !important;
  margin: 0 -5px;
  white-space: nowrap;
  width: 100%;
  max-width: 120px !important;
  text-overflow: ellipsis;
  overflow: hidden;
  position: relative;
}
.team-list .team-list .link-url:hover,
.team-list .team-list .link-title:hover {
  z-index: 20;
  overflow-x: auto;
  text-overflow: initial;
}
.team-list thead {
  display: none !important;
}
.team-list tr {
  margin-bottom: 0 !important;
  flex-grow: 1;
}
.team-list tr td:nth-of-type(2) {
  flex-grow: 1;
}
.team-list .acf-label {
  display: none !important;
}
.team-list table > tbody {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
}