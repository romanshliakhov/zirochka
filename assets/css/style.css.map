.langs {
  position: relative;
  display: flex;
}
.langs__trigger {
  display: flex;
  cursor: pointer;
}
.langs__body {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  top: calc(100% + 1rem);
}
.langs__list {
  padding: 0 0.5rem;
  background-color: var(--cl-c);
  display: flex;
  flex-direction: column;
  border-radius: 1.2rem;
}
.langs__item {
  padding: 1rem 0.5rem;
  font-family: var(--font-heading);
  font-size: 16px;
  line-height: 100%;
  font-weight: 400;
  transition: all 0.3s ease;
}
.langs__item:not(:last-child) {
  border-bottom: 0.1rem solid var(--cl-h);
}
@media (hover: hover) {
  .langs__item:hover {
    color: var(--cl-h);
  }
}
@media (hover: none) {
  .langs__item:active {
    color: var(--cl-h);
  }
}
.langs__item.active {
  color: var(--cl-h);
  font-weight: 700;
}

.social {
  position: relative;
  display: flex;
}
.social__trigger {
  display: flex;
  cursor: pointer;
}
.social__body {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  top: calc(100% + 1rem);
}
.social__list {
  padding: 1rem;
  background-color: var(--cl-c);
  border-radius: 1.2rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.social__item {
  display: flex;
  align-items: center;
  gap: 1rem;
}
.social__item span {
  font-family: var(--font-main);
  font-size: 1.6rem;
  line-height: 150%;
  font-weight: 400;
}

.menu {
  display: flex;
  align-items: center;
  gap: 3rem;
}

.header {
  padding: 10px 0;
  z-index: 30;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  width: 100%;
  background-color: var(--cl-f);
}
@media (max-width: 1024px) {
  .header {
    padding: 0;
  }
}
.header.open-menu {
  z-index: 30;
}
.header__box {
  display: flex;
  align-items: center;
  gap: 4rem;
}
.header__logo {
  display: flex;
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
}
.header__top {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 10px;
  width: 100%;
  position: relative;
  z-index: 1;
}
.header__top .burger {
  display: none;
}
.header__nav {
  flex-grow: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}
.header__info {
  display: flex;
  align-items: center;
  gap: 2rem;
}
.header__socials {
  display: flex;
  align-items: center;
  gap: 2rem;
}
.header__currency {
  font-family: var(--font-heading);
  font-size: 2rem;
  line-height: 150%;
  font-weight: 400;
}
.header__controls {
  display: flex;
  align-items: center;
  gap: clamp(10px, 1.042vw, 20px);
