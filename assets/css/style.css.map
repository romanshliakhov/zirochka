  content: "";
  position: absolute;
  inset: 0;
  background-color: rgba(0, 0, 0, 0.45);
  border-radius: 0 0 1.5rem 1.5rem;
}
.article__title {
  font-size: clamp(38px, 4.688vw, 48px);
  line-height: 130%;
}
.article__inner {
  position: relative;
  z-index: 5;
  margin-top: -30px;
  max-width: 1280px;
  width: 100%;
  display: grid;
  align-items: flex-start;
  gap: 30px;
}
@media (min-width: 992px) {
  .article__inner {
    grid-template-columns: auto 1fr 337px;
  }
}
@media (max-width: 991px) {
  .article__inner {
    grid-template-columns: 100px 1fr;
  }
}
@media (max-width: 575px) {
  .article__inner {
    grid-template-columns: 1fr;
  }
}
.article__share {
  padding: clamp(15px, 2.791vw, 30px) 15px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: clamp(15px, 2.791vw, 30px);
  background-color: var(--cl-c);
  border-radius: 8px;
}
@media (min-width: 576px) {
  .article__share {
    position: sticky;
    top: 100px;
  }
}
.article__share-heading {
  font-family: var(--font-heading);
  font-size: 14px;
  line-height: 100%;
  font-weight: 700;
  color: var(--cl-d);
}
.article__share-socials {
  display: flex;
  gap: 10px;
}
@media (min-width: 576px) {
  .article__share-socials {
    flex-direction: column;
  }
}
.article__content {
  padding: 2rem;
  background-color: var(--cl-a);
  border-radius: 0.8rem;
  display: flex;
  flex-direction: column;
  gap: 1.2rem;
}
@media (max-width: 575px) {
  .article__content {
    order: -1;
  }
}
.article__thumbnail {
  display: flex;
}
.article__thumbnail img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 1.2rem;
}
.article__related {
  display: flex;
  flex-direction: column;
  gap: 30px;
}
@media (max-width: 1024px) {
  .article__related {
    grid-column: 1/-1;
  }
}
.article__related .news-card {
  background-color: var(--cl-c);
}
.article__related .news-card__thumb {
  height: 100%;
}

.blog-list {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 4rem;
  margin-right: -0.5rem;
}
.blog-list__item {
  position: relative;
  z-index: 1;
  grid-column: span 3;
}
@media (min-width: 992px) {
  .blog-list__item:nth-child(even):not(.mode):before {
    content: none;
  }
}
@media (max-width: 991px) {
  .blog-list__item:first-of-type:before {
    content: none;
  }
}
.blog-list__item:before {
  content: "";
  position: absolute;
  height: 100%;
  width: 0.1rem;
  right: -2rem;
  transform: translateX(50%);
  background: #CCC;
  pointer-events: none;
}
@media (max-width: 991px) {
  .blog-list__item:before {
    top: -20px;
    width: 100vw;
    height: 1px;
    left: 50%;
    transform: translate(-50%, -50%);
  }
}
@media (max-width: 991px) and (max-width: 575px) {
  .blog-list__item:before {
    top: -23.5px;
  }
}
.blog-list__item.mode {
  grid-column: span 2;
  z-index: 3;
  margin: 4rem 0;
}
@media (min-width: 992px) {
  .blog-list__item.mode:nth-child(5n):before {
    content: none;
  }
}
.blog-list__item.mode.highlight {
  position: relative;
  z-index: 2;
}
@media (min-width: 992px) {
  .blog-list__item.mode.highlight:after {
    position: absolute;
    content: "";
    width: 100vw;
    z-index: -1;
    pointer-events: none;
    height: calc(100% + 8rem);
    background: var(--cl-g);
    top: 50%;
    left: calc(50% - 0.5rem);
    transform: translate(-50%, -50%);
  }
}
@media (max-width: 991px) {
  .blog-list__item.mode.highlight {
    margin: -43px 0 -41px;
    z-index: 4;
  }
  .blog-list__item.mode.highlight:after {
    height: calc(100% + 7.5rem);
  }
  .blog-list__item.mode.highlight + .mode {
    z-index: 5;
  }
}
@media (max-width: 575px) {
  .blog-list__item.mode.highlight {
    margin: -40px 0 -40px;
  }
  .blog-list__item.mode.highlight + .mode {
    margin-bottom: 31px;
  }
}
@media (max-width: 991px) {
  .blog-list__item.mode:has(+ .highlight):before {
    content: none !important;
  }
}
@media (max-width: 575px) {
  .blog-list__item.mode:has(+ .highlight) {
    margin-top: 9px;
  }
  .blog-list__item.mode:has(+ .highlight):after {
    height: calc(100% + 64px);
  }
}
@media (max-width: 375px) {
  .blog-list__item.mode:has(+ .highlight):after {
    height: calc(100% + 64px);
  }
}
.blog-list__item.mode .blog-card__box p:not([class]) {
  -webkit-line-clamp: 3;
}
@media (max-width: 1440px) and (min-width: 576px) {
  .blog-list__item.mode .blog-card__box p:not([class]) {
    -webkit-line-clamp: 4;
  }
}
@media (max-width: 575px) {
  .blog-list__item.mode .blog-card__box p:not([class]) {
    max-width: 100%;
    -webkit-line-clamp: 4;
  }
}
@media (max-width: 991px) {
  .blog-list__item.mode {
    margin: 40px 0;
  }
  .blog-list__item.mode:after {
    position: absolute;
    content: "";
    width: 100vw;
    z-index: -1;
    pointer-events: none;
    height: calc(100% + 8rem);
    background: var(--cl-g);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }
}
@media (max-width: 991px) {
  .blog-list__item {
    grid-column: initial !important;
  }
}
@media (max-width: 1440px) {
  .blog-list {
    gap: 42px 40px;
    margin: 0 -7px 0 3px;
  }
}
@media (max-width: 1240px) {
  .blog-list {
    margin: 0 -5px 0 0;
  }
}
@media (max-width: 991px) {
  .blog-list {
    margin: 0;
    grid-template-columns: 100%;
    gap: 40px;
  }
}
@media (max-width: 575px) {
  .blog-list {
    gap: 47px;
  }
}

.blog-card {
  height: 100%;
  display: flex;
  flex-direction: column;
  gap: 2.3rem;
  position: relative;
  z-index: 1;
}
.blog-card__box {
  height: 100%;
  display: flex;
  flex-direction: column;
  gap: 2.5rem;
  justify-content: flex-end;
  min-width: 0;
}
.blog-card__box .h3 {
  margin-bottom: auto;
}
@media (max-width: 575px) {
  .blog-card__box .h3 {
    min-height: 30px;
  }
}
.blog-card__box .h2, .blog-card__box .h3 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}
.blog-card__box p:not([class]) {
  font-family: var(--font-second);
  display: -webkit-box;
  line-height: 150%;
  font-size: 1.6rem;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  letter-spacing: 0.008em;
  margin-bottom: auto;
}
@media (max-width: 1440px) {
  .blog-card__box p:not([class]) {
    -webkit-line-clamp: 3;
    letter-spacing: 0.01em;
  }
}
@media (max-width: 1440px) and (min-width: 1241px) {
  .blog-card__box p:not([class]) {
    max-width: 95%;
  }
}
@media (max-width: 575px) {
  .blog-card__box p:not([class]) {
    -webkit-line-clamp: 4;
  }
}
@media (max-width: 575px) and (min-width: 376px) {
  .blog-card__box p:not([class]) {
    max-width: 95%;
  }
}
@media (max-width: 575px) {
  .blog-card__box {
    gap: 16px;
  }
}
.blog-card__bottom {
  display: flex;
  align-items: center;
  gap: 1.6rem;
  flex-wrap: nowrap;
  min-width: 0;
  margin-top: -0.2rem;
}
@media (max-width: 575px) {
  .blog-card__bottom {
    margin: -1px 0 0 2px;
  }
}
.blog-card__info {
  display: flex;
  align-items: center;
  gap: 0.8rem;
  white-space: nowrap;
  flex-shrink: 0;
  font-size: 1.4rem;
  font-style: normal;
  font-weight: 500;
  line-height: normal;
}
.blog-card__info:last-child {
  flex: 1;
  min-width: 0;
}
.blog-card__info:last-child span {
  display: block;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.blog-card__info svg {
  flex-shrink: 0;
}
.blog-card__image {
  z-index: -1;
  width: 100%;
  overflow: hidden;
  display: flex;
  flex-shrink: 0;
  height: 30rem;
}
.blog-card__image img, .blog-card__image picture, .blog-card__image svg {
  width: 100%;
  height: 100%;
  transition: all 0.5s;
}
@media (max-width: 575px) {
  .blog-card__image {
    height: 200px;
  }
}
.blog-card .tag {
  position: absolute;
  top: 0.8rem;
  left: 0.8rem;
  background-color: var(--cl-d);
  color: var(--cl-a);
}
@media (hover: hover) {
  .blog-card:hover .blog-card__image img, .blog-card:hover .blog-card__image picture, .blog-card:hover .blog-card__image svg {
    transform: scale(1.06);
  }
}
@media (hover: none) {
  .blog-card:active .blog-card__image img, .blog-card:active .blog-card__image picture, .blog-card:active .blog-card__image svg {
    transform: scale(1.06);
  }
}
@media (max-width: 575px) {
  .blog-card {
    gap: 24px;
  }
}