.cta-slider .swiper-slide {
  position: relative;
  opacity: 0 !important;
  transition: opacity 0.2s ease-out, transform 0.4s ease-out;
}
.cta-slider .swiper-slide.swiper-slide-visible {
  opacity: 1 !important;
