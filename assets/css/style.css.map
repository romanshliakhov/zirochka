[data-btn-modal] svg {
  pointer-events: none;
}

.modal {
  position: relative;
  margin: auto;
  transform: scale(0.8);
  display: none;
}
.modal::before {
  position: absolute;
  content: "";
  z-index: -1;
  pointer-events: none;
  inset: 0;
}
.modal [data-loader]::before {
  background-color: rgba(217, 219, 218, 0);
  inset: -5px;
}
.modal [data-loader=true]::before {
  opacity: 1;
}
.modal.active {
  transform: scale(1);
}
.modal__container {
  width: 100%;
  display: flex;
  justify-content: center;
  margin: 0 auto;
}
.modal .close {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 5;
  right: 15px;
  top: 15px;
  transition: all 0.3s;
  color: var(--cl-a);
  opacity: 0.5;
  cursor: pointer;
}
.modal .close:hover {
  opacity: 1;
}
.modal .close svg {
  pointer-events: none;
}

[data-loader] {
  position: relative;
  z-index: 10;
}
[data-loader]::before, [data-loader]::after {
  content: "";
  position: absolute;
  z-index: 10;
  pointer-events: none;
  opacity: 1;
  transition: all 0.3s ease;
}
[data-loader]::before {
  inset: -2px;
  backdrop-filter: blur(6px);
  border-radius: 0.8rem;
}
[data-loader]::after {
  top: 50%;
  left: 50%;
  width: clamp(100px, 12vw, 160px);
  aspect-ratio: 1;
  border-radius: 50%;
  background: var(--loader);
  animation: spin 1.2s linear infinite;
  transform: translate(-50%, -50%);
  padding: clamp(12px, 2vw, 24px);
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
}

@keyframes spin {
  to {
    transform: translate(-50%, -50%) rotate(1turn);
  }
}
[data-loader=false]::before,
[data-loader=false]::after {
  opacity: 0;
}

